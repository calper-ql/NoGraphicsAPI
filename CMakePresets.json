{
    "version": 8,
    "configurePresets": [
        {
            "name": "linux",
            "displayName": "Linux (Ninja, GLFW backend)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "NGAPI_WINDOW_BACKEND": "GLFW"
            }
        },
        {
            "name": "linux-sdl3",
            "displayName": "Linux (Ninja, SDL3 backend)",
            "inherits": "linux",
            "binaryDir": "${sourceDir}/build/sdl3",
            "cacheVariables": {
                "NGAPI_WINDOW_BACKEND": "SDL3"
            }
        },
        {
            "name": "vs2022-x64",
            "displayName": "Visual Studio 2022 (x64)",
            "generator": "Visual Studio 17 2022",
            "toolset": "host=x64",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/vs2022-x64",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            }
        }
    ],
    "buildPresets": [
        { "name": "linux", "configurePreset": "linux" },
        { "name": "linux-sdl3", "configurePreset": "linux-sdl3" },
        { "name": "vs2022-x64-release", "configurePreset": "vs2022-x64", "configuration": "Release" }
    ]
}
